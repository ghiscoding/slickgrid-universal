{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: ['config:base', 'group:allNonMajor'],
  labels: ['📦 dependencies', '🤖 bot'],
  dependencyDashboard: true,
  minimumReleaseAge: '2 days',
  // since all PRs touches the pnpm lock file, let's open not more than 2 PRs at the same time
  prConcurrentLimit: 2,
  rangeStrategy: 'bump',
  packageRules: [
    {
      depTypeList: ['peerDependencies'],
      enabled: false,
    },
    {
      description: 'Group all Angular dependencies',
      matchFileNames: ['frameworks/angular-slickgrid/**', 'demos/angular/**', 'frameworks-plugins/angular-row-detail-plugin/**'],
      groupName: 'Angular dependencies',
      ignoreDeps: ['typescript'],
      major: {
        enabled: false,
      },
    },
    // i18next major version - let's wait until our next major
    {
      packageNames: ['i18next'],
      allowedVersions: '< 26.0.0',
    },
    {
      packageNames: ['react-i18next'],
      allowedVersions: '< 17.0.0',
    },
    // postponed the following npm packages to next major, since they now require NodeJS: ^22.22.2 || ^24.15.0 || >=26.0.0
    {
      packageNames: ['npm-run-all2'],
      allowedVersions: '< 9.0.0',
    },
    {
      matchManagers: ['github-actions'],
      matchDepNames: ['pnpm/action-setup'],
      allowedVersions: '< 6.0.0',
      description: 'Keep pnpm action at v5 until we migrate to pnpm v11',
    },
    {
      // Exclude @lerna-lite/* from minimumReleaseAge since I'm the maintainer of Lerna-Lite
      matchPackagePatterns: ['^@lerna-lite/'],
      minimumReleaseAge: '0',
    },
  ],
  ignoreDeps: ['lee-dohm/no-response', 'node', 'pnpm', 'typescript'],
  schedule: ['every 4 weeks on friday'],
}
